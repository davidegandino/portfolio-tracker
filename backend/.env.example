# Alpha Vantage API Key
# Ottieni gratis su: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=tua_api_key_qui

# JWT Secret per autenticazione
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=tuo_secret_segreto_qui

# Ambiente (development o production)
ENVIRONMENT=development

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:8000,https://portfolio-tracker-xxx.onrender.com

# Admin User (primo accesso)
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=CambiaQuestaPassword123!
